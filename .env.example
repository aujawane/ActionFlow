# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_APP_URL=http://localhost:3000

# Production examples (Vercel):
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# INTERNAL_APP_URL=https://your-app.vercel.app

# Optional explicit Recall webhook URL for documentation/ops.
# If unset, Parfait derives: ${NEXT_PUBLIC_APP_URL}/api/recall/webhook
# Production: https://your-app.vercel.app/api/recall/webhook
# Local (ngrok): https://<your-ngrok-domain>/api/recall/webhook
RECALL_WEBHOOK_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Per attempt; execution-intelligence makes at most two attempts per stage.
EXECUTION_INTELLIGENCE_TIMEOUT_MS=60000

RECALL_API_KEY=
RECALL_REGION=us-west-2
RECALL_WEBHOOK_SECRET=

# Zoom Server-to-Server OAuth (no browser callback URL)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# Google OAuth (user-connected Google Meet)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local:
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# Production:
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/integrations/google/callback

# Optional legacy/global Google Meet refresh token used by meeting-providers fallback
GOOGLE_REFRESH_TOKEN=
